        <mxCell id="normal-text" parent="1" style="fontFamily=宋体;text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=10;fontColor=#333333;" value="模式 0: 正常&#xa;逐步恢复 V_bus&#xa;逐步恢复 Fan" vertex="1">
