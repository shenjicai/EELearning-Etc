        </mxCell>
        <mxCell id="arr-mode1" edge="1" parent="1" source="decision-second" style="fontFamily=宋体;endArrow=classic;html=1;strokeColor=#d79b00;strokeWidth=2;exitX=0;exitY=0.5;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;edgeStyle=orthogonalEdgeStyle;labelBackgroundColor=none" target="mode1-box" value="">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="115" y="413" />
            </Array>
          </mxGeometry>
        </mxCell>
        <mxCell id="label-mode1" parent="1" style="fontFamily=宋体;text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=10;fontStyle=1;fontColor=#d79b00;" value="5 &lt; ΔT ≤ 8°C" vertex="1">
          <mxGeometry height="35" width="90" x="190" y="410" as="geometry" />
        </mxCell>
        <mxCell id="mode1-box" parent="1" style="fontFamily=宋体;rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d79b00;strokeWidth=2;" value="" vertex="1">
          <mxGeometry height="80" width="170" x="30" y="500" as="geometry" />
        </mxCell>
        <mxCell id="mode1-label" parent="1" style="fontFamily=宋体;text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=10;fontColor=#333333;" value="模式 1: 轻度风险&#xa;仅增加母线电压&#xa;V_bus += 15V/周期&#xa;（逐级增量, 不超 V_max）" vertex="1">
          <mxGeometry height="75" width="160" x="35" y="505" as="geometry" />
        </mxCell>
        <mxCell id="arr-mode1-back" edge="1" parent="1" source="mode1-box" style="fontFamily=宋体;endArrow=classic;html=1;strokeColor=#d79b00;strokeWidth=1.5;dashed=1;exitX=0;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;edgeStyle=orthogonalEdgeStyle;labelBackgroundColor=none" target="start" value="">
