        </mxCell>
        <mxCell id="t1to0-label" parent="1" style="fontFamily=宋体;text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=11;fontStyle=1;fontColor=#2e7d32;" value="ΔT ≤ 5°C&#xa;(风险消除)" vertex="1">
