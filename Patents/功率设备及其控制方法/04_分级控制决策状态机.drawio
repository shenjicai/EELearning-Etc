        <mxCell id="t2to0" edge="1" parent="1" source="state2" style="fontFamily=宋体;endArrow=classic;html=1;strokeColor=#82b366;strokeWidth=2.5;exitX=0.5;exitY=0;exitDx=0;exitDy=0;entryX=0.906;entryY=0.791;entryDx=0;entryDy=0;curved=1;labelBackgroundColor=none;entryPerimeter=0;" target="state0" value="">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="t2to0-label" parent="1" style="fontFamily=宋体;text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=11;fontStyle=1;fontColor=#2e7d32;" value="ΔT ≤ 5°C&#xa;(快速恢复)" vertex="1">
          <mxGeometry height="35" width="80" x="690" y="230" as="geometry" />
        </mxCell>
        <mxCell id="t2to1" edge="1" parent="1" source="state2" style="fontFamily=宋体;endArrow=classic;html=1;strokeColor=#d79b00;strokeWidth=2.5;exitX=0;exitY=1;exitDx=0;exitDy=0;entryX=1;entryY=1;entryDx=0;entryDy=0;labelBackgroundColor=none" target="state1" value="">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="t2to1-label" parent="1" style="fontFamily=宋体;text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=11;fontStyle=1;fontColor=#e65100;" value="5 &lt; ΔT ≤ 8°C&#xa;(降级)" vertex="1">
          <mxGeometry height="35" width="90" x="440" y="430" as="geometry" />
        </mxCell>
        <mxCell id="safety-box" parent="1" style="fontFamily=宋体;rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;strokeWidth=2;" value="" vertex="1">
          <mxGeometry height="220" width="350" x="60" y="560" as="geometry" />
        </mxCell>
        <mxCell id="safety-title" parent="1" style="fontFamily=宋体;text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=13;fontStyle=1;fontColor=#333333;" value="安全边界与约束" vertex="1">
          <mxGeometry height="25" width="350" x="60" y="565" as="geometry" />
        </mxCell>
        <mxCell id="safety-content" parent="1" style="fontFamily=宋体;text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=10;fontColor=#333333;" value="电压安全范围: V_bus ∈ [580, 880]V&#xa;  → 下限 580V: 并网最低门槛&#xa;  → 上限 880V: IGBT/MOSFET 耐压限值&#xa;&#xa;风扇转速范围: Fan ∈ [15, 100]%&#xa;  → 下限 15%: 保证最小散热能力&#xa;  → 上限 100%: 额定转速&#xa;&#xa;逐级增量约束:&#xa;  → dV_step = 15V/周期 (每 20s)&#xa;  → 避免电压突变对电网的冲击&#xa;&#xa;采样周期: T_sample = 20s&#xa;  → 热时间常数 ~385s → 20s 采样合理" vertex="1">
          <mxGeometry height="155" width="320" x="75" y="595" as="geometry" />
        </mxCell>
        <mxCell id="physics-box" parent="1" style="fontFamily=宋体;rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;strokeWidth=2;" value="" vertex="1">
          <mxGeometry height="230" width="350" x="470" y="560" as="geometry" />
        </mxCell>
        <mxCell id="physics-title" parent="1" style="fontFamily=宋体;text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=13;fontStyle=1;fontColor=#333333;" value="两级升温机制对比" vertex="1">
          <mxGeometry height="25" width="350" x="470" y="565" as="geometry" />
        </mxCell>
        <mxCell id="physics-content" parent="1" style="fontFamily=宋体;text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=10;fontColor=#333333;" value="【机制 1】增加母线电压 (V_bus↑)&#xa;  P_loss = P_loss0 × (V_bus / V_nom)²&#xa;  → V_bus 从 620→680V: P_loss 增加 20.3%&#xa;  → 模块自身 I²R 损耗增加 → 主动产热&#xa;  → 优点: 直接、可靠、无需额外硬件&#xa;&#xa;【机制 2】降低风扇转速 (Fan↓)&#xa;  R_th = R_th0 × (Fan_nom / Fan)&#xa;  → 热阻增大 → 散热减缓 → 热量积累&#xa;  → 注意: T_mod &lt; T_amb 时&#xa;     降低风扇会减少环境→模块的热传导&#xa;  → 主要作用: 减少湿气流 → 物理防凝露" vertex="1">
          <mxGeometry height="155" width="320" x="485" y="595" as="geometry" />
        </mxCell>
