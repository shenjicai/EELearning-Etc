        <mxCell id="block-ploss-detail" parent="1" style="fontFamily=宋体;text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=9;fontColor=#555555;" value="V_ratio = V_bus / V_nom&#xa;Square = (V_ratio)²&#xa;P_loss = P_loss0 × Square&#xa;= 55 × (V_bus/620)²" vertex="1">
